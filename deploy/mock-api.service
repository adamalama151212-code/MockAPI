[Unit]
Description=Polymorphic Mock Telemetry API (FastAPI + Uvicorn)
After=network.target

[Service]
Type=simple
User=ubuntu
# Directory containing main.py and the data files (frigate.db, *.jsonl, camera_device_map.json)
WorkingDirectory=/home/ubuntu/app
ExecStart=/home/ubuntu/app/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
